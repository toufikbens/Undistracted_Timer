{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Undistracted Timer",
  "version": "0.1.0",
  "identifier": "dev.undistracted.timer",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Undistracted Timer",
        "url": "index.html?runtime=tauri",
        "width": 1040,
        "height": 760,
        "minWidth": 720,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "capabilities": ["default", "mobile"]
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Copyright 2026 Toufik Bens",
    "shortDescription": "A quiet interval timer for focused work.",
    "longDescription": "Undistracted Timer is a minimalist timer for focused work sessions, intentional breaks, and gentle ambient sound.",
    "icon": [
      "../web/assets/favicon.png"
    ],
    "android": {
      "minSdkVersion": 26
    }
  }
}
